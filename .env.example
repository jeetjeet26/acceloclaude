# ── Accelo Credentials ──────────────────────────────────────────────────────
# Your Accelo deployment name (the subdomain before .accelo.com)
# e.g. if your URL is p11creative.accelo.com → deployment = p11creative
ACCELO_DEPLOYMENT=your-deployment

# Service application credentials from Accelo API settings
# Settings > API > Create Application → choose "Service Application"
ACCELO_CLIENT_ID=your-client-id@your-deployment.accelo.com
ACCELO_CLIENT_SECRET=your-client-secret

# ── Server Config ─────────────────────────────────────────────────────────────
PORT=3000

# Optional: protect this MCP server with a bearer token.
# Set this to any strong random string, then enter it in Claude's connector settings.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_AUTH_TOKEN=
